generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(CONSULTANT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  empresas      Empresa[] // Relation to managed companies
}

enum UserRole {
  ADMIN
  MANAGER
  CONSULTANT
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Aviso {
  // ========== EXISTING BASIC INFO (16 fields) ==========
  id                  String              @id @default(cuid())
  nome                String
  portal              Portal              @default(PORTUGAL2030)
  programa            String
  linha               String?
  codigo              String
  dataInicioSubmissao DateTime
  dataFimSubmissao    DateTime
  montanteMinimo      Float?
  montanteMaximo      Float?
  descrição         String?
  link                String?
  taxa                String?
  regiao              String?
  setoresElegiveis    String[]
  dimensaoEmpresa     String[]
  urgente             Boolean             @default(false)
  ativo               Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  // ========== NEW: ENRICHMENT METADATA ==========
  enrichmentStatus    EnrichmentStatus    @default(BASIC)
  enrichmentScore     Float?
  dataSourceLog       Json?
  lastEnrichedAt      DateTime?
  enrichedBy          String?

  // ========== NEW: FINANCIAL PARAMETERS (12 fields) ==========
  taxaCofinanciamentoMin       Float?
  taxaCofinanciamentoMax       Float?
  taxaGrandeEmpresa            Float?
  taxaMediaEmpresa             Float?
  taxaPequenaEmpresa           Float?
  taxaMicroEmpresa             Float?
  limiteMinimoCandidatura      Decimal?  @db.Decimal(15, 2)
  limiteMaximoCandidatura      Decimal?  @db.Decimal(15, 2)
  limiteMaximoEmpresa          Decimal?  @db.Decimal(15, 2)
  comparticipacaoPublicaMax    Float?
  contribuicaoPropriaMin       Float?
  percentagemFNR               Float?

  // ========== NEW: GEOGRAPHIC SCOPE (5 fields) ==========
  regiaoNUTS2                  String?
  regiaoNUTS3                  String[]  @default([])
  municipiosElegiveis          String[]  @default([])
  abrangenciaGeografica        AbrangenciaGeografica?
  limitacaoTerritorial         String?   @db.Text

  // ========== NEW: ELIGIBILITY CRITERIA (10 fields) ==========
  caeElegiveis                 Int[]     @default([])
  caeExcluidos                 Int[]     @default([])
  tiposBeneficiarios           TipoBeneficiario[]  @default([])
  formaJuridicaRequerida       String[]  @default([])
  situacaoRegularizada         Boolean   @default(true)
  antiguidadeMinima            Int?
  trabalhadoresMinimo          Int?
  volumeNegociosMinimo         Decimal?  @db.Decimal(15, 2)
  criacaoEmpregoObrigatoria    Boolean   @default(false)

  // ========== NEW: FUNDING STRUCTURE (8 fields) ==========
  fundoEstruturalPrincipal     FundoEstrutural?
  fundosCofinanciamento        Json?
  programaOperacionalCodigo    String?
  eixoPrioritario              String?
  prioridadeInvestimento       String?
  objetivoEspecificoCodigo     String?
  regimeAuxilio                RegimeAuxilio?
  artigoGBER                   String?

  // ========== NEW: INVESTMENT TYPES (6 fields) ==========
  categoriasInvestimentoElegiveis  CategoriaInvestimento[]  @default([])
  custosElegiveis              Json?
  custosNaoElegiveis           Json?
  tipoOperacao                 TipoOperacao?
  tipoApoio                    TipoApoio?
  reembolsavel                 Boolean   @default(false)

  // ========== NEW: PROJECT REQUIREMENTS (7 fields) ==========
  duracaoMinimaProjeto         Int?
  duracaoMaximaProjeto         Int?
  prazoExecucaoMeses           Int?
  periodoManutencaoAnos        Int?
  apresentacaoPlanoNegocios    Boolean   @default(false)
  parecerTecnicoObrigatorio    Boolean   @default(false)
  estudoViabilidadeObrigatorio Boolean   @default(false)

  // ========== NEW: SUBMISSION & DEADLINES (5 fields) ==========
  tipoSubmissao                TipoSubmissao?
  fasesSubmissao               Int       @default(1)
  prazoReclamacao              Int?
  dataDecisaoEstimada          DateTime?
  prazoContratacaoDias         Int?

  // ========== NEW: COMPLIANCE & DOCUMENTATION (6 fields) ==========
  documentosObrigatorios       String[]  @default([])
  declaracoesNecessarias       String[]  @default([])
  regulamentoURL               String?
  anexosRegulamento            String[]  @default([])
  baseLegalPrincipal           String?   @db.Text
  normativoComunitario         String?   @db.Text

  // ========== NEW: PDF PROCESSING (8 fields) ==========
  pdfStoragePath               String?
  pdfHash                      String?
  pdfDownloadStatus            PDFStatus?            @default(NOT_STARTED)
  pdfDownloadedAt              DateTime?
  pdfExtractionStatus          PDFStatus?            @default(NOT_STARTED)
  pdfExtractedText             String?               @db.Text
  pdfExtractionQuality         Float?
  pdfMetadata                  Json?

  // ========== MIGRATION TRACKING ==========
  migratedFromLegacy           Boolean   @default(false)
  migrationVersion             String?
  migrationErrors              String[]  @default([])

  // ========== RELATIONS ==========
  candidaturas        Candidatura[]
  memorias            MemoriaDescritiva[]

  @@index([enrichmentStatus])
  @@index([enrichmentScore])
  @@index([portal, enrichmentStatus])
  @@index([regiaoNUTS2])
  @@index([regimeAuxilio])
  @@map("avisos")
}

// ========== LEGACY SNAPSHOT TABLE ==========
model AvisoLegacy {
  id        String   @id
  snapshot  Json
  createdAt DateTime @default(now())

  @@map("avisos_legacy_snapshot")
}

model Empresa {
  id               String              @id @default(cuid())
  nipc             String              @unique
  nome             String
  cae              String
  setor            String
  dimensao         DimensaoEmpresa     @default(MICRO)
  email            String
  telefone         String?
  morada           String?
  localidade       String?
  codigoPostal     String?
  distrito         String?
  regiao           String?
  contactoNome     String?
  contactoEmail    String?
  contactoTelefone String?
  notas            String?
  ativa            Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  candidaturas     Candidatura[]
  documentos       Documento[]
  memorias         MemoriaDescritiva[]
  gestores         User[]              // Relation to consultants/managers
  
  @@map("empresas")
}

model Candidatura {
  id                 String            @id @default(cuid())
  empresaId          String
  avisoId            String
  estado             EstadoCandidatura @default(A_PREPARAR)
  montanteSolicitado Float?
  montanteAprovado   Float?
  dataSubmissao      DateTime?
  dataDecisao        DateTime?
  observacoes        String?
  documentosAnexos   String[]
  timeline           Json[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  aviso              Aviso             @relation(fields: [avisoId], references: [id])
  empresa            Empresa           @relation(fields: [empresaId], references: [id])
  complianceChecks   ComplianceCheck[] // Compliance engine relation

  @@map("candidaturas")
}

model Documento {
  id               String             @id @default(cuid())
  empresaId        String
  tipoDocumento    TipoDocumento
  nome             String
  cloudStoragePath String
  dataEmissao      DateTime?
  dataValidade     DateTime?
  statusValidade   StatusValidade     @default(VALIDO)
  observacoes      String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  empresa          Empresa            @relation(fields: [empresaId], references: [id])
  evidences        DocumentEvidence[] // Document intelligence relation

  @@map("documentos")
}

model Workflow {
  id              String        @id @default(cuid())
  nome            String
  tipo            TipoWorkflow
  ativo           Boolean       @default(true)
  frequencia      String
  ultimaExecucao  DateTime?
  proximaExecucao DateTime?
  parametros      Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  logs            WorkflowLog[]

  @@map("workflows")
}

model WorkflowLog {
  id           String   @id @default(cuid())
  workflowId   String
  dataExecucao DateTime
  sucesso      Boolean
  mensagem     String?
  dados        Json?
  createdAt    DateTime @default(now())
  workflow     Workflow @relation(fields: [workflowId], references: [id])

  @@map("workflow_logs")
}

model Notificacao {
  id           String          @id @default(cuid())
  tipo         TipoNotificacao
  destinatario String
  assunto      String
  conteudo     String
  enviado      Boolean         @default(false)
  dataEnvio    DateTime?
  erro         String?
  contexto     Json?
  createdAt    DateTime        @default(now())

  @@map("notificacoes")
}

model APIConfig {
  id              String      @id @default(cuid())
  userId          String
  provider        LLMProvider @default(ABACUS_AI)
  abacusApiKey    String?
  anthropicApiKey String?
  openaiApiKey    String?
  isActive        Boolean     @default(true)
  chatbotModel    String      @default("claude-4-5-haiku")
  memoriaModel    String      @default("claude-4-5-sonnet")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("api_configs")
}

model MemoriaDescritiva {
  id             String         @id @default(cuid())
  empresaId      String
  avisoId        String
  titulo         String
  status         StatusMemoria  @default(RASCUNHO)
  dadosEmpresa   Json
  dadosAviso     Json
  dadosProjeto   Json?
  modeloUsado    String?
  tempoGeracao   Int?
  qualityScore   Float?
  erros          String[]
  warnings       String[]
  versao         Int            @default(1)
  versaoAnterior String?
  docxPath       String?
  pdfPath        String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  seccoes        MemoriaSecao[]
  aviso          Aviso          @relation(fields: [avisoId], references: [id])
  empresa        Empresa        @relation(fields: [empresaId], references: [id])

  @@map("memorias_descritivas")
}

model MemoriaSecao {
  id           String            @id @default(cuid())
  memoriaId    String
  numeroSeccao Int
  titulo       String
  conteudo     String
  status       StatusSeccao      @default(NAO_GERADA)
  tempoGeracao Int?
  tokenCount   Int?
  tabelas      Json[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  memoria      MemoriaDescritiva @relation(fields: [memoriaId], references: [id], onDelete: Cascade)

  @@unique([memoriaId, numeroSeccao])
  @@map("memoria_seccoes")
}

model KnowledgeBase {
  id        String        @id @default(cuid())
  tipo      TipoKnowledge
  titulo    String
  conteudo  String
  embedding String?
  metadados Json?
  ativo     Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("knowledge_base")
}

