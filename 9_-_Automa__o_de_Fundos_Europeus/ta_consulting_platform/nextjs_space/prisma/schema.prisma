// ============================================================================
// COMPLIANCE ENGINE MODELS (Sprint 1.1)
// ============================================================================

model ComplianceRule {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Rule identification
  programa    String   // "PT2030", "PRR", "PEPACC"
  versao      String   // "2024", "2025"
  ruleId      String   // "PT2030_ELIG_001", "PRR_INTENS_002"

  // Rule details
  categoria   String   // "eligibility", "intensity", "costs", "thresholds", "regional", "procedural"
  titulo      String
  descricao   String   @db.Text
  baseLegal   String   // "DL_20A_2023_ART_14", "REG_EU_651_2014_ART_53"
  formula     String?  @db.Text  // Python expression for evaluation
  severidade  String   // "BLOQUEANTE", "AVISO", "INFO"
  notas       String[] @default([])

  // Status
  ativo       Boolean  @default(true)

  // Relations
  checks      ComplianceCheck[]

  @@unique([programa, versao, ruleId])
  @@index([programa, versao, ativo])
  @@index([categoria])
  @@index([severidade])
  @@map("compliance_rules")
}

model ComplianceCheck {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())

  // Foreign keys
  candidaturaId   String
  candidatura     Candidatura @relation(fields: [candidaturaId], references: [id], onDelete: Cascade)

  ruleId          String
  rule            ComplianceRule @relation(fields: [ruleId], references: [id])

  // Check result
  status          String   // "PASS", "FAIL", "WARNING", "SKIP"
  valorEsperado   String?
  valorObtido     String?
  notas           String[] @default([])
  evidencias      Json?    // Store any evidence data

  // Metadata
  timestamp       DateTime @default(now())
  checkedBy       String?  // User ID who triggered check
  programa        String   // Denormalized for quick queries
  versao          String   // Denormalized for quick queries

  @@index([candidaturaId, status])
  @@index([ruleId])
  @@index([programa, versao])
  @@index([timestamp])
  @@map("compliance_checks")
}

model DocumentEvidence {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())

  // Foreign key (Note: will be added to Documento model in Sprint 1.2)
  documentoId   String
  documento     Documento @relation(fields: [documentoId], references: [id], onDelete: Cascade)

  // Chain of custody
  sha256Hash    String
  timestamp     DateTime @default(now())
  signedBy      String?  // User ID
  ipAddress     String?
  userAgent     String?
  fileSize      Int?     // Bytes
  mimeType      String?

  @@index([documentoId])
  @@index([sha256Hash])
  @@index([timestamp])
  @@map("document_evidences")
}

// ============================================================================
// AUDIT LOGS (Compliance & Rastreabilidade)
// ============================================================================

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // User who performed the action
  userId    String
  userName  String?  // Denormalized for performance
  userEmail String?  // Denormalized for performance

  // Action details
  action    AuditAction  // CREATE, UPDATE, DELETE, LOGIN, etc.
  entity    String       // "Aviso", "Empresa", "Candidatura", etc.
  entityId  String       // ID of the affected entity
  
  // Change tracking
  changes   Json?        // Diff of changes (before/after)
  metadata  Json?        // Additional context (IP, user agent, etc.)
  
  // Request context
  ipAddress String?
  userAgent String?
  method    String?      // HTTP method (POST, PUT, DELETE)
  path      String?      // Request path
  
  // Categorization
  severity  AuditSeverity @default(INFO)  // INFO, WARNING, CRITICAL
  category  String?       // "FINANCIAL", "COMPLIANCE", "ADMIN", etc.
  
  @@index([userId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
  @@index([severity])
  @@map("audit_logs")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  EXPORT
  IMPORT
}

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}

